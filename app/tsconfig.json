{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": [
      "node"
    ],
    "paths": {
      "@renderer/*": [
        "./src/renderer/src/*"
      ],
      "@main/*": [
        "./src/main/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "electron.vite.config.ts"
  ]
}
